# URL del controlador de dominio
LDAP_URL=ldap://tu-servidor-ad:389

# Base DN de busqueda (raiz del dominio)
LDAP_BASE_DN=DC=tudominio,DC=com

# Cuenta de servicio — usar formato UPN o DN completo (NO usar DOMINIO\usuario)
# Formato UPN:     serviceaccount@tudominio.com
# Formato DN:      CN=svcPrint,OU=ServiceAccounts,DC=tudominio,DC=com
LDAP_USER=serviceaccount@tudominio.com
LDAP_PASS=contraseña_de_la_cuenta_de_servicio

# Intervalo de consulta al spooler en milisegundos (5000 = 5 segundos)
POLL_INTERVAL_MS=5000
